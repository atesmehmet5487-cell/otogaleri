# ─────────────────────────────────────────────────────────────────────────────
#  .env.example  —  copy to .env.local and fill in.
#
#  The guided setup ("/setup" in Claude Code) does this FOR you: it asks which
#  integrations you want, collects each key, and writes .env.local.
#
#  Every key here is OPTIONAL. With none set, the app runs in DEMO MODE with
#  realistic sample data so you can see it immediately.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (database & auth) ───────────────────────────────────────────────
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
